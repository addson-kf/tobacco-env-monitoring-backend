<!--                #{town},-->
<!--                #{village},-->
<!--                #{progress},-->
<!--                #{monitoringPointID})-->
<!--            ON CONFLICT ("CountyDistrict","Town","Village")-->
<!--        DO UPDATE SET-->
<!--            "Progress" = EXCLUDED."Progress",-->
<!--                           "MonitoringPointID" = EXCLUDED."MonitoringPointID"-->
<!--    </insert>-->

    <!-- 如果你的模型是“一村多监测点、多行”，请把唯一键改为
         ("CountyDistrict","Town","Village","MonitoringPointID")
         并把上面 ON CONFLICT 的冲突列改成四列。 -->

    <!-- 根据 ID 更新所有字段 -->
    <update id="updateCountyProgressById" parameterType="org.example.model.CountyProgress">
        UPDATE public."CountyProgress"
        SET "CountyDistrict"   = #{countyDistrict},
            "Town"             = #{town},
            "Village"          = #{village},
            "Progress"         = #{progress},
            "MonitoringPointID" = #{monitoringPointID}
        WHERE "CountyId" = #{countyId}
    </update>

    <!-- 单条查询 -->
    <select id="findOne" resultMap="CountyProgressMap">
        SELECT * FROM public."CountyProgress"
        WHERE "CountyDistrict" = #{county}
          AND "Town" = #{town}
          AND "Village" = #{village}
            LIMIT 1
    </select>

    <!-- 过滤列表 -->
    <select id="list" resultMap="CountyProgressMap">
        SELECT *
        FROM public."CountyProgress"
        WHERE 1=1
        <if test="county != null and county != ''">
            AND "CountyDistrict" = #{county}
        </if>
        <if test="town != null and town != ''">
            AND "Town" = #{town}
        </if>
        <if test="village != null and village != ''">
            AND "Village" = #{village}
        </if>
        ORDER BY "CountyId" ASC   <!-- 改为按主键递增排序 -->
    </select>

    <!-- 分页计数 -->
    <select id="countByFilter" resultType="long">
        SELECT COUNT(1)
        FROM public."CountyProgress"
        WHERE 1=1
        <if test="county != null and county != ''">
            AND "CountyDistrict" = #{county}
        </if>
        <if test="town != null and town != ''">
            AND "Town" = #{town}
        </if>
        <if test="village != null and village != ''">
            AND "Village" = #{village}
        </if>
    </select>

    <!-- 分页列表 -->
    <select id="pageByFilter" resultMap="CountyProgressMap">
        SELECT *
        FROM public."CountyProgress"
        WHERE 1=1
        <if test="county != null and county != ''">
            AND "CountyDistrict" = #{county}
        </if>
        <if test="town != null and town != ''">
            AND "Town" = #{town}
        </if>
        <if test="village != null and village != ''">
            AND "Village" = #{village}
        </if>
        ORDER BY "CountyId" ASC   <!-- 改为按主键递增排序 -->
        LIMIT #{size} OFFSET #{offset}
    </select>







</mapper>