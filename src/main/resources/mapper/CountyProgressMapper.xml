<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.mapper.CountyProgressMapper">
    <resultMap id="CountyProgressMap" type="org.example.model.CountyProgress">
        <id     property="countyId"       column="CountyId"/>
        <result property="countyDistrict" column="CountyDistrict"/>
        <result property="town"           column="Town"/>
        <result property="village"        column="Village"/>
        <result property="progress"       column="Progress"/>
        <result property="monitoringPointID" column="MonitoringPointID"/>
    </resultMap>

    <!-- 插入 -->
    <insert id="insert" parameterType="org.example.model.CountyProgress" useGeneratedKeys="true" keyProperty="countyId">
        INSERT INTO public."CountyProgress"
            ("CountyDistrict",
             "Town",
             "Village",
             "Progress",
             "MonitoringPointID")
        VALUES
            (#{countyDistrict},
             #{town},
             #{village},
             #{progress},
             #{monitoringPointID})
    </insert>

    <insert id="upsert" parameterType="org.example.model.CountyProgress">
        INSERT INTO public."CountyProgress"
            ("CountyDistrict","Town","Village","Progress","MonitoringPointID")
        VALUES (#{countyDistrict},#{town},#{village},#{progress},#{monitoringPointID})
            ON CONFLICT ("CountyDistrict","Town","Village")
  DO UPDATE SET
            "Progress" = EXCLUDED."Progress",
                     "MonitoringPointID" = EXCLUDED."MonitoringPointID"
    </insert>

    <!-- UPSERT：
         如果你“一个 CTV 只保留一行”，请先在库里建唯一键 (CountyDistrict,Town,Village)
         然后用下面这个 upsert（冲突时更新 Progress & MonitoringPointID）
    -->

<!--    <insert id="upsert" parameterType="org.example.model.CountyProgress">-->
<!--        INSERT INTO public."CountyProgress"-->
<!--            ("CountyDistrict",-->
