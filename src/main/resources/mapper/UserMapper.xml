<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.UserMapper">
    <!--数据映射-->
    <resultMap id="userResultMap" type="org.example.model.User">
        <id property="userId" column="UserId"/>  <!-- 主键映射 -->
        <result property="account" column="Account"/>
        <result property="password" column="Password"/>
        <result property="admin" column="IsAdmin"/>
        <result property="delete" column="IsDelete"/>
    </resultMap>
    <!--注册用户-->
    <insert id="createUser">
        INSERT INTO "Users" ("Account", "Password", "IsAdmin")
        VALUES (#{account}, #{password}, #{isAdmin});
    </insert>
    <!-- 删除角色 -->
    <delete id="deleteUser" parameterType="int">
        UPDATE "Users"
        SET "IsDelete" = true
        WHERE "UserId" = #{userId};
    </delete>
    <!--恢复已删除的角色-->
    <update id="restoreUser" parameterType="int">
        UPDATE "Users"
        SET "IsDelete" = false
        WHERE "UserId" = #{userId};
    </update>
    <!-- 更新密码 -->
    <update id="updatePassword" parameterType="map">
        UPDATE "Users"
        SET "Password" = #{password}
        WHERE "UserId" = #{userId};
    </update>

    <!-- 更新为管理员 -->
    <update id="updateToAdmin" parameterType="int">
        UPDATE "Users"
        SET "IsAdmin" = true
        WHERE "UserId" = #{userId};
    </update>

    <!-- 查询所有角色 -->
    <select id="findAllUsers" resultMap="userResultMap">
        SELECT * FROM "Users";
    </select>

    <!-- 通过用户 ID 查找用户 -->
    <select id="findUserById" resultMap="userResultMap">
        SELECT * FROM "Users" WHERE "UserId" = #{userId};
    </select>

    <!-- 通过账号查找用户（不查询密码）-->
    <select id="findUserByAccount" resultMap="userResultMap">
        SELECT * FROM "Users" WHERE "Account" = #{account};
    </select>

    <!--通过账号查询用户是否被删除-->
    <select id="isUserDeletedByAccount" resultType="boolean">
        SELECT "IsDelete" FROM "Users" WHERE "Account" = #{account};
    </select>
</mapper>